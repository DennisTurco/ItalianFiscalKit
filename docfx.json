{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "ItalianFiscalKit",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "README.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      },
      {
        "files": [
          "coverage/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "ItalianFiscalKit",
      "_appTitle": "ItalianFiscalKit",
      "_appLogoPath": "images/icon.svg",
      "_appFaviconPath": "images/icon.png",
      "_enableSearch": true,
      "pdf": true,
      "_gitContribute": {
        "repo": "https://github.com/DennisTurco/ItalianFiscalKit",
        "branch": "master"
      },
      "_appFooter": "<span>Built with <a href='https://dotnet.github.io/docfx' target='_blank'>DocFX</a> · <a href='https://github.com/DennisTurco/ItalianFiscalKit' target='_blank'>GitHub</a> · <a href='https://www.nuget.org/packages/ItalianFiscalKit' target='_blank'>NuGet</a> · <a href='https://github.com/sponsors/DennisTurco' target='_blank'>❤️ Sponsor</a></span>"
    }
  }
}